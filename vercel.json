{
  "buildCommand": null,
  "outputDirectory": ".",
  "framework": null,
  "rewrites": [
    { "source": "/library.html", "destination": "/library.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/js/(.*)",
      "headers": [{ "key": "Content-Type", "value": "application/javascript" }]
    }
  ]
}
